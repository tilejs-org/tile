{
  "name": "@tile.js/cli",
  "version": "1.1.1",
  "description": "CLI oficial do TileJS",
  "type": "module",
  "bin": {
    "tile": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "NODE_ENV=development bun src/index.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "tile",
    "tilejs",
    "tooling",
    "command-line"
  ],
  "author": "Israel R. Jatobá",
  "license": "MIT",
  "homepage": "https://tile.js.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/tilejs-org/tile.git"
  },
  "bugs": {
    "url": "https://github.com/tilejs-org/tile/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@tile.js/config": "latest",
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "chalk": "^5.6.2",
    "consola": "^3.4.2",
    "ora": "^9.4.1"
  }
}