{
  "name": "@tile.js/database",
  "version": "1.1.0",
  "homepage": "https://tile.js.org/",
  "license": "MIT",
  "type": "module",
  "description": "Um mecanismo de armazenamento com validação de esquema e segurança.",
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "Israel R. Jatobá",
    "url": "https://github.com/yeyTaken"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tilejs-org/tile",
    "directory": "packages/database"
  },
  "bugs": {
    "url": "https://github.com/tilejs-org/tile/issues"
  },
  "keywords": [
    "database",
    "bson",
    "bun",
    "nodejs",
    "typescript",
    "embedded-database",
    "local-database",
    "document-database"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./adapters/default": {
      "types": "./dist/adapters/default/index.d.ts",
      "import": "./dist/adapters/default/index.js"
    },
    "./adapters/mongodb": {
      "types": "./dist/adapters/mongodb/index.d.ts",
      "import": "./dist/adapters/mongodb/index.js"
    },
    "./adapters/mongoose": {
      "types": "./dist/adapters/mongoose/index.d.ts",
      "import": "./dist/adapters/mongoose/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/bun": "catalog:",
    "@tile.js/config": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "bson": "^7.3.0"
  },
  "scripts": {
    "typegen": "tsc",
    "build": "bun run ./build.ts",
    "test": "bun run build && node --test ./tests/*.test.mjs",
    "dev": "bun run ./playground/index.ts"
  }
}
