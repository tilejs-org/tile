{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "rootDir": "src",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "skipLibCheck": true,
        "verbatimModuleSyntax": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "src"
    ]
}